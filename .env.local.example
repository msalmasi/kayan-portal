# ─── Supabase (required) ───────────────────────────────────────
# Public keys — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Payment — Receiving Wallets ───────────────────────────────
# Public: displayed to investors on the payment page
NEXT_PUBLIC_RECEIVING_WALLET_ETH=0xYourEthereumWallet
NEXT_PUBLIC_RECEIVING_WALLET_SOL=YourSolanaWallet

# Server-side: used by on-chain verification (can match public ones)
RECEIVING_WALLET_ETH=0xYourEthereumWallet
RECEIVING_WALLET_SOL=YourSolanaWallet

# ─── Payment — On-chain Verification ──────────────────────────
# Etherscan API key (free tier: 5 req/sec) — https://etherscan.io/apis
ETHERSCAN_API_KEY=your-etherscan-key
# Solana RPC endpoint (defaults to public mainnet if blank)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Payment — Wire Transfer Instructions ─────────────────────
WIRE_BANK_NAME=Your Bank Name
WIRE_ACCOUNT_NAME=Kayan Forest Ltd
WIRE_ACCOUNT_NUMBER=123456789
WIRE_ROUTING_NUMBER=021000021
WIRE_SWIFT_CODE=YOURSWFT
